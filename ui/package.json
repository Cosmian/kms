{
    "name": "ui",
    "private": true,
    "version": "5.21.0",
    "type": "module",
    "packageManager": "pnpm@10.17.1",
    "scripts": {
        "dev": "VITE_DEV_MODE=true vite",
        "preview": "vite preview",
        "build": "pnpm run build:wasm && pnpm run build:vite",
        "build:wasm": "cd .. && wasm-pack build crate/clients/wasm --target web --release --features non-fips && node ui/scripts/sync-wasm.mjs",
        "build:vite": "tsc -b && vite build",
        "check": "tsc --noEmit && pnpm run check:lint && pnpm run check:format && pnpm run check:dedup",
        "check:lint": "eslint . --fix",
        "check:format": "prettier . --write",
        "check:dedup": "knip",
        "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
        "test:unit": "vitest --run -c tests/vitest.unit.config.ts",
        "test:integration": "vitest --run -c tests/vitest.int.config.ts",
        "test:e2e": "playwright test",
        "test:wasm": "cd .. && bash .github/scripts/nix.sh --variant non-fips test wasm"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.0",
        "@tailwindcss/vite": "^4.2.0",
        "antd": "^5.29.3",
        "moment": "^2.30.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.13.0",
        "tailwindcss": "^4.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@playwright/test": "^1.51.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^3.11.0",
        "eslint": "^9.39.3",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "jsdom": "^26.1.0",
        "knip": "^6.2.0",
        "prettier": "^3.8.1",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.56.0",
        "vite": "^7.3.2",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "supportedArchitectures": {
            "os": [
                "current",
                "linux",
                "darwin",
                "win32"
            ],
            "cpu": [
                "current",
                "x64",
                "arm64"
            ]
        },
        "overrides": {
            "esbuild": "^0.25.10",
            "@babel/runtime": "^7.26.10",
            "minimatch": ">=10.2.1",
            "picomatch": ">=4.0.4",
            "rollup": ">=4.59.0",
            "ajv": "^6.14.0",
            "flatted": ">=3.4.2"
        },
        "onlyBuiltDependencies": [
            "@playwright/test",
            "@swc/core",
            "bcrypt",
            "canvas",
            "esbuild",
            "nodegit",
            "playwright",
            "sharp",
            "sodium-native"
        ]
    }
}
